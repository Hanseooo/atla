# Application
ENVIRONMENT=development
SECRET_KEY=your-random-secret-key-here-change-in-production

# Database URLs (both required, selected based on ENVIRONMENT)
# Development: Local PostgreSQL (pgAdmin)
DEV_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/atla_db
# Production: Supabase
PROD_DATABASE_URL=postgresql+asyncpg://postgres:password@db.project-ref.supabase.co:5432/postgres

# Supabase Auth
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT Secret: Found in Supabase Dashboard > Project Settings > API > JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret

# APIs
# Google Gemini (for LLM intent extraction and itinerary generation)
GOOGLE_API_KEY=your-google-api-key
# Brave Search API (optional, future upgrade from DuckDuckGo)
BRAVE_API_KEY=your-brave-api-key
# Geoapify (for geocoding and places search)
GEOAPIFY_API_KEY=your-geoapify-api-key
# OpenWeather (for weather forecasts)
OPENWEATHER_API_KEY=your-openweather-api-key

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
